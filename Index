<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Happy Birthday Anita 🤍</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Dancing+Script:wght@400;700&family=Cormorant+Garamond:ital,wght@0,300;1,400&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden;font-family:'Cormorant Garamond',serif;cursor:none}
:root{--gold:#c9a84c;--gold2:#e8c97a;--white:#fffdf8}
.cursor{position:fixed;width:14px;height:14px;background:var(--gold);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);mix-blend-mode:multiply}
.screen{position:fixed;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 1s ease;overflow:hidden}
.screen.active{opacity:1;pointer-events:all}
#nav{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);display:flex;gap:10px;z-index:100}
.dot{width:9px;height:9px;border-radius:50%;background:transparent;border:1.5px solid var(--gold);cursor:pointer;transition:all 0.3s}
.dot.active{background:var(--gold);transform:scale(1.3)}
.btn{font-family:'Cinzel',serif;font-size:0.65rem;letter-spacing:0.2em;padding:9px 26px;border:1.5px solid var(--gold);background:transparent;color:var(--gold);cursor:pointer;transition:all 0.3s;margin-top:22px;position:relative;z-index:2}
.btn:hover{background:var(--gold);color:#fff}

/* music player bar */
#mbar{position:fixed;top:14px;left:50%;transform:translateX(-50%);z-index:200;display:flex;align-items:center;gap:10px;background:rgba(255,253,248,0.88);border:1px solid rgba(201,168,76,0.5);padding:7px 16px;backdrop-filter:blur(6px)}
#mbar span{font-family:'Cinzel',serif;font-size:0.6rem;letter-spacing:0.2em;color:var(--gold);text-transform:uppercase}
#mbar button{background:transparent;border:1px solid var(--gold);color:var(--gold);font-size:0.75rem;padding:4px 10px;cursor:pointer;font-family:'Cinzel',serif;letter-spacing:0.1em;transition:all 0.3s}
#mbar button:hover{background:var(--gold);color:#fff}
/* hidden youtube iframe */
#yt{position:fixed;width:1px;height:1px;opacity:0;pointer-events:none;top:-100px}

/* S1 */
#s1{background:var(--white)}
#s1::before,#s1::after{content:'';position:absolute;border:1px solid rgba(201,168,76,0.35);pointer-events:none}
#s1::before{inset:16px}#s1::after{inset:23px}
.c{position:absolute;width:34px;height:34px;border-color:var(--gold);border-style:solid;opacity:.7}
.c.tl{top:10px;left:10px;border-width:2px 0 0 2px}.c.tr{top:10px;right:10px;border-width:2px 2px 0 0}
.c.bl{bottom:10px;left:10px;border-width:0 0 2px 2px}.c.br{bottom:10px;right:10px;border-width:0 2px 2px 0}
#s1 .sub{font-family:'Cinzel',serif;font-size:.62rem;letter-spacing:.35em;color:var(--gold);text-transform:uppercase;margin-bottom:12px;animation:up 1.2s .3s both}
.fname{font-family:'Cinzel',serif;font-size:clamp(3rem,8vw,6.5rem);font-weight:700;background:linear-gradient(135deg,#2a1f0e,var(--gold),#2a1f0e);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:up 1.2s .7s both}
.lname{font-family:'Cormorant Garamond',serif;font-size:clamp(.85rem,2vw,1.3rem);letter-spacing:.5em;color:var(--gold);text-transform:uppercase;font-weight:300;animation:up 1.2s .9s both;display:block;margin-top:4px}
.divv{display:flex;align-items:center;gap:12px;margin:16px 0;animation:up 1.2s 1.1s both}
.divv::before,.divv::after{content:'';flex:1;max-width:65px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.divv span{color:var(--gold)}
.vwrap{position:relative;width:min(380px,88vw);border:1px solid var(--gold);box-shadow:0 0 30px rgba(201,168,76,.12);animation:up 1.2s 1.3s both}
.vwrap::before{content:'';position:absolute;inset:-5px;border:1px solid rgba(201,168,76,.2);pointer-events:none}
.vwrap video{width:100%;height:180px;object-fit:cover;display:block;background:#1a1208}
.vlabel{font-family:'Dancing Script',cursive;font-size:.92rem;color:var(--gold);text-align:center;padding:6px;background:rgba(255,253,248,.95)}
.note{position:absolute;color:var(--gold);opacity:0;animation:floatN var(--d,4s) ease-in infinite;animation-delay:var(--dl,0s);font-size:1.1rem}
@keyframes floatN{0%{opacity:0;transform:translateY(0)}20%{opacity:.7}100%{opacity:0;transform:translateY(-70px)}}

/* S2 */
#s2{background:linear-gradient(145deg,#180808,#2d0f0f,#180a14)}
.hfield{position:absolute;inset:0;overflow:hidden;pointer-events:none}
.hp{position:absolute;bottom:-5%;animation:rise var(--d,4s) ease-in infinite;animation-delay:var(--dl,0s);opacity:0}
@keyframes rise{0%{opacity:0;transform:translateY(0) scale(.5)}15%{opacity:1;transform:translateY(-20px) scale(1.1)}85%{opacity:.5}100%{opacity:0;transform:translateY(-110vh) scale(.6)}}
.bigh{font-size:clamp(3.5rem,9vw,6.5rem);animation:hb 1.4s ease-in-out infinite;filter:drop-shadow(0 0 20px rgba(220,50,50,.7))}
@keyframes hb{0%,100%{transform:scale(1)}14%{transform:scale(1.2)}28%{transform:scale(1)}42%{transform:scale(1.1)}}
.ilym{font-family:'Cinzel',serif;font-size:clamp(2rem,6vw,4.5rem);font-weight:700;letter-spacing:.1em;background:linear-gradient(135deg,#fff,var(--gold2),#fff);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:sh 3s linear infinite}
@keyframes sh{0%{background-position:0% center}100%{background-position:200% center}}
.ilynamee{font-family:'Dancing Script',cursive;font-size:clamp(1.8rem,4.5vw,3.2rem);color:var(--gold2);text-shadow:0 0 18px rgba(201,168,76,.5)}
.ilysub{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.08rem;color:rgba(255,255,255,.6);max-width:340px;line-height:1.7;text-align:center}
.ilybb{position:absolute;font-family:'Dancing Script',cursive;color:rgba(255,255,255,.14);pointer-events:none;animation:bd var(--bd,6s) ease-in-out infinite alternate}
@keyframes bd{0%{transform:translateY(0) rotate(var(--br,0deg));opacity:.1}100%{transform:translateY(-26px) rotate(calc(var(--br,0deg)+5deg));opacity:.22}}
#s2 .inner2{display:flex;flex-direction:column;align-items:center;gap:14px;position:relative;z-index:2}

/* S3 */
#s3{background:var(--white)}
#s3 .glow{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(201,168,76,.07) 0%,transparent 70%)}
.s3h{font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.35em;color:var(--gold);text-transform:uppercase;margin-bottom:7px;text-align:center}
.s3t{font-family:'Cormorant Garamond',serif;font-size:clamp(1.7rem,4vw,2.6rem);font-style:italic;font-weight:300;color:#2a1f0e;text-align:center;margin-bottom:20px;line-height:1.2}
.s3t span{color:var(--gold);font-style:normal;font-weight:600}
.rgrid{display:grid;grid-template-columns:1fr 1fr;gap:10px;max-width:560px;width:90vw;position:relative;z-index:2}
.rc{background:rgba(255,253,248,.95);border:1px solid rgba(201,168,76,.3);padding:13px 15px;position:relative;overflow:hidden;animation:up .9s ease both}
.rc::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--gold)}
.rc .em{font-size:1.3rem;margin-bottom:4px;display:block}
.rc p{font-family:'Cormorant Garamond',serif;font-size:.9rem;line-height:1.5;color:#5c4a2a;font-style:italic}

/* S4 */
#s4{background:linear-gradient(160deg,#0e0a04,#1c1208,#0e0a04);overflow-y:auto}
.gp{position:absolute;border-radius:50%;background:var(--gold);opacity:0;animation:gpf var(--gpd,5s) ease-in-out infinite;animation-delay:var(--gdd,0s)}
@keyframes gpf{0%,100%{opacity:0;transform:translateY(0) scale(1)}50%{opacity:.35;transform:translateY(-36px) scale(1.5)}}
#s4 .in4{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;padding:44px 22px 80px;max-width:520px;margin:0 auto}
.pframe{position:relative;margin-bottom:24px;width:min(260px,76vw)}
.pframe::before{content:'';position:absolute;inset:-11px;border:1px solid rgba(201,168,76,.5);pointer-events:none}
.pframe::after{content:'';position:absolute;inset:-18px;border:1px solid rgba(201,168,76,.18);pointer-events:none}
.pframe img{width:100%;display:block;aspect-ratio:1/1;object-fit:cover;filter:sepia(15%) brightness(1.03)}
.pc2{position:absolute;width:18px;height:18px;border-color:var(--gold);border-style:solid;z-index:2}
.pc2.tl{top:-11px;left:-11px;border-width:2px 0 0 2px}.pc2.tr{top:-11px;right:-11px;border-width:2px 2px 0 0}
.pc2.bl{bottom:-11px;left:-11px;border-width:0 0 2px 2px}.pc2.br{bottom:-11px;right:-11px;border-width:0 2px 2px 0}
.bdlabel{font-family:'Cinzel',serif;font-size:.6rem;letter-spacing:.4em;color:var(--gold);text-transform:uppercase;margin-bottom:8px;text-align:center}
.bdtitle{font-family:'Cinzel',serif;font-size:clamp(1.4rem,4vw,2.4rem);font-weight:700;letter-spacing:.06em;text-align:center;background:linear-gradient(135deg,#fff,var(--gold2),#fff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:3px}
.bdname{font-family:'Dancing Script',cursive;font-size:clamp(1.6rem,4vw,2.6rem);color:var(--gold2);text-align:center;text-shadow:0 0 16px rgba(201,168,76,.4);margin-bottom:20px}
.gline{width:100px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:16px auto}
.msg{font-family:'Cormorant Garamond',serif;font-size:1rem;line-height:1.85;color:rgba(255,253,248,.78);text-align:center;font-style:italic;max-width:440px}
.msg p{margin-bottom:12px}
.sig{font-family:'Dancing Script',cursive;font-size:1.4rem;font-style:normal;color:var(--gold2)}
@keyframes up{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
</style>
</head>
<body>

<div class="cursor" id="cur"></div>

<!-- Music bar -->
<div id="mbar">
  <span>🎵 Birthday Music</span>
  <button onclick="toggleMusic()" id="mbtn">▶ Play</button>
</div>

<!-- Hidden YouTube iframe – soft romantic piano playlist -->
<iframe id="yt" src="https://www.youtube.com/embed/videoseries?list=PLJNe1l_BWCZ6kJBjUeHVWNIBFrpT2rYmA&autoplay=0&loop=1&controls=0&mute=0" allow="autoplay" frameborder="0"></iframe>

<!-- S1 -->
<div class="screen active" id="s1">
  <div id="notes"></div>
  <div class="c tl"></div><div class="c tr"></div><div class="c bl"></div><div class="c br"></div>
  <p class="sub">✦ A very special day for a very special soul ✦</p>
  <div style="text-align:center">
    <div class="fname">Anita</div>
    <span class="lname">Rorisang Gaolebogwe</span>
  </div>
  <div class="divv"><span>♡</span></div>
  <div class="vwrap">
    <video autoplay muted loop playsinline><source src="https://www.w3schools.com/html/mov_bbb.mp4" type="video/mp4"/></video>
    <div class="vlabel">🎵 For you, always — Happy Birthday 🎵</div>
  </div>
  <button class="btn" onclick="goTo(1)">Continue ›</button>
</div>

<!-- S2 -->
<div class="screen" id="s2">
  <div class="hfield" id="hf"></div>
  <div id="ibb"></div>
  <div class="inner2">
    <span class="bigh">❤️</span>
    <div class="ilym">I Love You</div>
    <div class="ilynamee">Anita 🤍</div>
    <p class="ilysub">Every day. Every hour. Every heartbeat.<br/>You are my baby, my calm, the reason i am always smiling. 💫</p>
    <button class="btn" onclick="goTo(2)">Continue ›</button>
  </div>
</div>

<!-- S3 -->
<div class="screen" id="s3">
  <div class="glow"></div>
  <p class="s3h">✦ Written As it is from my heart ✦</p>
  <h2 class="s3t">Why you make my world <span>complete</span></h2>
  <div class="rgrid">
    <div class="rc" style="animation-delay:.1s"><span class="em">🌸</span><p>Your smile is the first thing I think of every morning. It lights up every room — and my whole world.</p></div>
    <div class="rc" style="animation-delay:.3s"><span class="em">💛</span><p>The way you love — so deeply, so genuinely. You remind me what beautiful truly means.</p></div>
    <div class="rc" style="animation-delay:.5s"><span class="em">🕊️</span><p>You bring peace to my soul. Wherever you are feels like home to me, always.</p></div>
    <div class="rc" style="animation-delay:.7s"><span class="em">✨</span><p>You are rare, Baby. The kind of rare the world was lucky enough to have — and I'm lucky enough to love.</p></div>
  </div>
  <button class="btn" onclick="goTo(3)">Our Special Message ›</button>
</div>

<!-- S4 -->
<div class="screen" id="s4">
  <div id="gpc"></div>
  <div class="in4">
    <div class="pframe">
      <img src="C:\Users\lorat\Downloads\IMG-20260519-WA0060.jpg" alt="Us"/>
      <div class="pc2 tl"></div><div class="pc2 tr"></div><div class="pc2 bl"></div><div class="pc2 br"></div>
    </div>
    <p class="bdlabel">✦ Today & Always ✦</p>
    <div class="bdtitle">Happy Birthday</div>
    <div class="bdname">Anita Rorisang 🎂</div>
    <div class="gline"></div>
    <div class="msg">
      <p>🌹 My dearest Anita, today the whole world celebrates the day you came into it — and honestly, it should. You are one of the most extraordinary people I have ever known.</p>
      <p>🌟 I wish you overflowing joy, peace that surpasses understanding, and love so deep it wraps around every part of you. May every dream you carry begin to bloom this year.</p>
      <p>💫 You deserve the world, the stars, the moon, and everything in between. I may not always show you in grand ways, but know that everything I am belongs to you.</p>
      <p>❤️ I love you more than words could ever capture. Always and forever, Anita. 🕊️</p>
      <div class="gline"></div>
      <p class="sig">With all my love 🤍</p>
    </div>
  </div>
</div>

<div id="nav">
  <div class="dot active" onclick="goTo(0)"></div>
  <div class="dot" onclick="goTo(1)"></div>
  <div class="dot" onclick="goTo(2)"></div>
  <div class="dot" onclick="goTo(3)"></div>
</div>

<script>
document.addEventListener('mousemove',e=>{const c=document.getElementById('cur');c.style.left=e.clientX+'px';c.style.top=e.clientY+'px';});

const scr=document.querySelectorAll('.screen'),dots=document.querySelectorAll('.dot');
let cur=0;
function goTo(n){scr[cur].classList.remove('active');dots[cur].classList.remove('active');cur=n;scr[cur].classList.add('active');dots[cur].classList.add('active');if(n===1)hearts();if(n===3)gold();}

// notes
const nc=['♩','♪','♫','♬'],ne=document.getElementById('notes');
for(let i=0;i<14;i++){const n=document.createElement('div');n.className='note';n.textContent=nc[i%4];n.style.left=Math.random()*94+'%';n.style.bottom=Math.random()*40+'%';n.style.setProperty('--d',(3+Math.random()*3)+'s');n.style.setProperty('--dl',(Math.random()*4)+'s');ne.appendChild(n);}

function hearts(){
  const f=document.getElementById('hf');f.innerHTML='';
  const em=['❤️','🧡','💛','🤍','💕','💗','💘','🌹'];
  for(let i=0;i<45;i++){const h=document.createElement('div');h.className='hp';h.textContent=em[i%em.length];h.style.left=Math.random()*100+'%';h.style.setProperty('--d',(3+Math.random()*4)+'s');h.style.setProperty('--dl',(Math.random()*5)+'s');h.style.fontSize=(1+Math.random()*1.4)+'rem';f.appendChild(h);}
  const ib=document.getElementById('ibb');ib.innerHTML='';
  const ph=['I love you ♡','Always & forever ✨','You are such a mini me 🤍','My Calmness💕','Forever yours 🌹'];
  for(let i=0;i<8;i++){const b=document.createElement('div');b.className='ilybb';b.textContent=ph[i%ph.length];b.style.left=Math.random()*82+'%';b.style.top=Math.random()*82+'%';b.style.fontSize=(1+Math.random())+'rem';b.style.setProperty('--bd',(4+Math.random()*4)+'s');b.style.setProperty('--br',(Math.random()*30-15)+'deg');ib.appendChild(b);}
}

function gold(){
  const g=document.getElementById('gpc');if(g.childElementCount)return;
  for(let i=0;i<28;i++){const p=document.createElement('div');p.className='gp';const s=2+Math.random()*4;p.style.cssText=`width:${s}px;height:${s}px;left:${Math.random()*100}%;top:${Math.random()*100}%`;p.style.setProperty('--gpd',(3+Math.random()*5)+'s');p.style.setProperty('--gdd',(Math.random()*4)+'s');g.appendChild(p);}
}

// Music via YouTube iframe API
let player, playing=false;
function onYouTubeIframeAPIReady(){
  player=new YT.Player('yt',{
    videoId:'4fndeDfaWCg', // "A Thousand Years" - soft romantic piano cover
    playerVars:{autoplay:0,loop:1,controls:0,playlist:'4fndeDfaWCg'},
    events:{onReady:()=>{player.setVolume(40);}}
  });
}
function toggleMusic(){
  if(!player)return;
  if(playing){player.pauseVideo();document.getElementById('mbtn').textContent='▶ Play';playing=false;}
  else{player.playVideo();document.getElementById('mbtn').textContent='⏸ Pause';playing=true;}
}
const tag=document.createElement('script');tag.src='https://www.youtube.com/iframe_api';document.head.appendChild(tag);

document.addEventListener('keydown',e=>{if(e.key==='ArrowRight')goTo(Math.min(cur+1,3));if(e.key==='ArrowLeft')goTo(Math.max(cur-1,0));});
let tx=0;
document.addEventListener('touchstart',e=>tx=e.touches[0].clientX);
document.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-tx;if(Math.abs(dx)>50)goTo(dx<0?Math.min(cur+1,3):Math.max(cur-1,0));});
</script>
</body>
</html>
